# ==============================================================================
# 8-Bit Task Quest & Pomodoro - .env.sample
# ==============================================================================
# 注意: このファイルはGitにコミットするためのサンプル（雛形）です。
# 開発を始める際は、このファイルをコピーして `.env` にリネームし、
# 実際のパスワードなどの値を入力して使用してください。
# コマンド例: cp .env.sample .env

# ------------------------------------------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------------------------------------------
# docker-compose.yml の db サービスに直接読み込まれる設定です。
MYSQL_ROOT_PASSWORD=super_secret_root_password_1234
MYSQL_DATABASE=task_quest_db
MYSQL_USER=quest_hero
MYSQL_PASSWORD=super_secret_password_1234
TZ=Asia/Tokyo